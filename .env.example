EXAMYE_DATABASE_URL=sqlite:///./examye.db
EXAMYE_UPLOAD_DIR=./data/uploads
EXAMYE_FRAME_DIR=./data/frames
EXAMYE_FRAME_INTERVAL_SECONDS=1.0
EXAMYE_MAX_FRAMES_PER_VIDEO=600

# YOLOv8 (auto-downloaded by ultralytics on first run, ~6 MB)
EXAMYE_YOLO_MODEL=yolov8n.pt
EXAMYE_YOLO_CONF=0.35
EXAMYE_SUSPICION_THRESHOLD=0.55

# ---- LLM backend ----
# "ollama"  → local Ollama daemon (default, recommended for 8 GB RAM)
# "openai"  → any OpenAI-compatible /v1/chat/completions endpoint (vLLM, OpenAI, LiteLLM, …)
# "stub"    → no network, deterministic templated summaries
EXAMYE_LLM_BACKEND=ollama

# Where the OpenAI-compatible chat endpoint lives. Ollama serves it at /v1.
EXAMYE_LLM_BASE_URL=http://localhost:11434/v1

# Ignored by Ollama. Used as Bearer token for OpenAI / vLLM.
EXAMYE_LLM_API_KEY=ollama

# Gemma 4 E2B fits on 8 GB RAM at 4-bit quant (~5 GB).
# Larger / smaller options: gemma4:e4b (more capable, ~6 GB RAM) · gemma3:1b (tiny)
EXAMYE_LLM_MODEL=gemma4:e2b

EXAMYE_LLM_TIMEOUT_SECONDS=120

# Ollama management API (used by `examye pull-model`, `examye models`, `examye ping`)
EXAMYE_OLLAMA_HOST=http://localhost:11434
